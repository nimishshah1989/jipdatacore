# Database
DATABASE_URL=postgresql+asyncpg://fie_admin:password@fie-db.c7osw6q6kwmw.ap-south-1.rds.amazonaws.com:5432/data_engine
DATABASE_URL_SYNC=postgresql+psycopg2://fie_admin:password@fie-db.c7osw6q6kwmw.ap-south-1.rds.amazonaws.com:5432/data_engine

# Redis
REDIS_URL=redis://:password@127.0.0.1:6379/0

# JWT
JWT_SECRET=load-from-aws-secrets-manager
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# AWS
AWS_REGION=ap-south-1
PII_KMS_KEY_ARN=arn:aws:kms:ap-south-1:ACCOUNT:key/KEY_ID
PII_HMAC_KEY_ARN=arn:aws:kms:ap-south-1:ACCOUNT:key/HMAC_KEY_ID

# Morningstar API
MORNINGSTAR_ACCESS_CODE=your-access-code-here
MORNINGSTAR_BASE_URL=https://api.morningstar.com/v2/service/mf

# External APIs
FRED_API_KEY=your-fred-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Goldilocks
GOLDILOCKS_EMAIL=from-secrets-manager
GOLDILOCKS_PASSWORD=from-secrets-manager

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# S3
S3_ARCHIVE_BUCKET=jsl-data-engine-archive

# App
APP_ENV=production
APP_PORT=8010
LOG_LEVEL=INFO

# Migration source databases
FIE_V3_DATABASE_URL=postgresql://fie_admin:password@fie-db.c7osw6q6kwmw.ap-south-1.rds.amazonaws.com:5432/fie_v3
MF_PULSE_DATABASE_URL=postgresql://fie:password@localhost:5432/mf_pulse
CLIENT_PORTAL_DATABASE_URL=postgresql://fie_admin:password@fie-db.c7osw6q6kwmw.ap-south-1.rds.amazonaws.com:5432/client_portal
