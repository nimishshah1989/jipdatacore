# Forge OS — Ralph Configuration
# Placed at .ralphrc in your project root by setup or /forge-build

# Claude CLI — full path so gtimeout can find it in non-login shells
CLAUDE_CODE_CMD="/Users/nimishshah/.npm-global/bin/claude"

# Timeout per iteration (minutes) — prevents runaway sessions
CLAUDE_TIMEOUT_MINUTES=60

# Each loop gets a fresh Claude session — prevents corrupted session file
SESSION_CONTINUITY=false

# Max iterations before stopping — circuit breaker
MAX_ITERATIONS=25

# Tools Claude is allowed to use (safe git subcommands only)
CLAUDE_ALLOWED_TOOLS="Write,Read,Edit,Bash(git add *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(git push *),Bash(git pull *),Bash(git fetch *),Bash(git checkout *),Bash(git branch *),Bash(git stash *),Bash(git merge *),Bash(git tag *),Bash(npm *),Bash(pytest)"

# Auto-wait when rate limited (unattended mode)
UNATTENDED_MODE=true

# Session expiration (hours) — forces fresh context after this
SESSION_EXPIRY_HOURS=2
